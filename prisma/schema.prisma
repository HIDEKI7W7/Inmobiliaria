generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

generator client_root {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS Y TIPOS DE DATOS DE DOMINIO
// ==========================================

enum Role {
  ADMIN
  AGENTE
  PROPIETARIO
  CLIENTE
}

enum Currency {
  USD
  BOB
}

enum PropertyType {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
}

enum PropertyStatus {
  NUEVA_PUBLICACION
  APROBADO
  OBSERVADO
  LEGAL_VERDE      // Todo en regla
  LEGAL_AMARILLO   // Trámites en proceso
  LEGAL_ROJO       // Bloqueos legales/financieros
  RESERVADO
}

enum OfferType {
  VENTA
  ALQUILER
  ANTICRETICO
  PROYECTO
}


enum LeadOrigin {
  WEB
  WHATSAPP
  TELEGRAM
}

enum LeadStatus {
  LEAD_ENTRANTE
  CITA_AGENDADA
  VISITA_REALIZADA
  NEGOCIACION
  RESERVA
  CIERRE
  NUEVO             // Para retrocompatibilidad
  CONTACTADO
  EN_NEGOCIACION
  GANADO
  PERDIDO
}

// ==========================================
// MODELOS DEL SISTEMA (Tablas mapeadas a SQL)
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(CLIENTE)
  
  // Relaciones (1:N)
  properties      Property[] @relation("PropertyAgent") // Propiedades que gestiona el agente
  ownedProperties Property[] @relation("PropertyOwner") // Propiedades del propietario
  leads      Lead[]     // Leads asignados al agente para su atención

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Property {
  id          String         @id @default(uuid())
  title       String
  description String?        @db.Text
  price       Float
  minPrice    Float?         @map("min_price") // Precio Tope Mínimo (invisible para clientes)
  currency    Currency       @default(USD)
  type        PropertyType   @default(DEPARTAMENTO)
  offerType   OfferType      @default(VENTA) @map("offer_type")
  location    String         @default("Cochabamba")
  address     String?        // Dirección manual
  imageUrl    String?        @map("image_url")
  
  // Atributos físicos (Precisión métrica y geolocalización)
  rooms       Int            @default(0)
  bathrooms   Int            @default(0)
  area        Float          // Área construida en m²
  latitude    Float          // Latitud para renderizar en mapa Leaflet
  longitude   Float          // Longitud para renderizar en mapa Leaflet
  
  // Identidad de marca y semáforo legal
  isVerified  Boolean        @default(false) @map("is_verified") // Sello de Calidad / Sello Oro
  status      PropertyStatus @default(NUEVA_PUBLICACION)
  observationNotes String?   @map("observation_notes") @db.Text
  
  // Checklist Documental
  hasFolioReal       Boolean        @default(false) @map("has_folio_real")
  hasCatastro        Boolean        @default(false) @map("has_catastro")
  hasTestimonio      Boolean        @default(false) @map("has_testimonio")
  hasImpuestosAlDia  Boolean        @default(false) @map("has_impuestos_al_dia")
  hasPlanoUsoSuelo   Boolean        @default(false) @map("has_plano_uso_suelo")
  hasCI              Boolean        @default(false) @map("has_ci")

  // Relaciones
  agentId     String?        @map("agent_id")
  agent       User?          @relation("PropertyAgent", fields: [agentId], references: [id], onDelete: SetNull)
  ownerId     String?        @map("owner_id")
  owner       User?          @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leads       Lead[]         // Personas interesadas en este inmueble

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Índices para optimizar velocidad de consultas geoespaciales y relación
  @@index([agentId])
  @@index([ownerId])
  @@map("properties")
}

model Lead {
  id         String     @id @default(uuid())
  name       String
  phone      String
  email      String
  message    String?    @db.Text
  
  // Automatización & Orquestación Webhooks (ej. n8n)
  origin     LeadOrigin @default(WEB)
  status     LeadStatus @default(NUEVO)
  
  // Relaciones
  propertyId String     @map("property_id")
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  assignedAgentId String? @map("assigned_agent_id")
  assignedAgent   User?   @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)

  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Índices para búsquedas ultra-rápidas y triggers automáticos
  @@index([propertyId])
  @@index([assignedAgentId])
  @@map("leads")
}

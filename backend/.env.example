# =========================================================================
# PROPIO BACKEND (NestJS) - PLANTILLA DE VARIABLES DE ENTORNO (.env.example)
# =========================================================================
# Este archivo contiene todas las variables de entorno necesarias para la
# ejecución de la API REST de Propio y la persistencia de datos con Prisma.
#
# INSTRUCCIONES:
# 1. Copia este archivo a un nuevo archivo llamado '.env' en este mismo
#    directorio para tu desarrollo local.
# 2. Configura estas variables en el panel de control de Render (o tu
#    proveedor de hosting en la nube) para el entorno de producción.
# 3. NUNCA subas archivos '.env' reales o archivos '.env.production' a Git.
# =========================================================================

# -------------------------------------------------------------------------
# 1. Base de Datos (PostgreSQL con Prisma)
# -------------------------------------------------------------------------
# Conexión principal para Prisma. Reemplazar con tus credenciales.
# - Para local: postgresql://postgres:postgres@localhost:5432/propio?schema=public
# - Para producción (Neon/RDS): postgresql://<usuario>:<password>@<host>/propio_db?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://username:password@localhost:5432/propio_db?schema=public"

# -------------------------------------------------------------------------
# 2. Seguridad & Autenticación
# -------------------------------------------------------------------------
# Clave secreta de alta entropía (HMAC-SHA256 de 256 bits) para la firma y verificación
# de JSON Web Tokens (JWT). Utilizar una cadena única generada de forma segura.
# Puedes generar una clave aleatoria en consola con: openssl rand -hex 32
JWT_SECRET="your_secure_random_jwt_secret_key_at_least_32_characters"

# -------------------------------------------------------------------------
# 3. Control de Acceso (CORS) y Redirecciones
# -------------------------------------------------------------------------
# URL exacta del frontend permitida para consumir la API. Previene ataques CSRF.
# - Desarrollo: http://localhost:3000
# - Producción: https://propio-inmobiliaria.vercel.app
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"

# OAuth social login. Las URLs callback deben coincidir con:
# Google/Facebook: http://localhost:4000/api/auth/<provider>/callback
# Apple: http://localhost:4000/api/auth/apple/callback
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"
APPLE_CLIENT_ID="your_apple_service_id"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# -------------------------------------------------------------------------
# 4. Configuración del Servidor
# -------------------------------------------------------------------------
# Puerto local donde se levantará la aplicación NestJS.
# En Render, el puerto se asigna dinámicamente mediante la variable PORT.
PORT=4000

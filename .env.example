# =========================================================================
# PROPIO - PLANTILLA DE VARIABLES DE ENTORNO GLOBAL (.env.example)
# =========================================================================
# Este archivo contiene todas las variables de entorno necesarias para la
# ejecución del proyecto (Frontend y Backend).
#
# INSTRUCCIONES:
# 1. Copia este archivo a un nuevo archivo llamado '.env' o '.env.local'
#    en este mismo directorio, o configura estas variables en tu proveedor
#    de hosting (ej. Render para backend, Vercel para frontend).
# 2. Reemplaza los placeholders con tus valores reales de desarrollo.
# 3. NUNCA subas archivos '.env' reales o archivos '.env.production' a Git.
# =========================================================================

# -------------------------------------------------------------------------
# 1. CONFIGURACIÓN DEL BACKEND (NestJS / Prisma)
# -------------------------------------------------------------------------

# URL de conexión de la base de datos PostgreSQL.
# Reemplazar con tu base de datos local o de nube (ej. Neon, Supabase, RDS).
# Formato local: postgresql://<usuario>:<password>@<host>:<puerto>/<base_de_datos>?schema=public
# Formato nube: postgresql://<usuario>:<password>@<host>/<base_de_datos>?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/propio_db?schema=public"

# Llave secreta para la firma y verificación de JSON Web Tokens (JWT).
# Generar una clave segura y única de alta entropía (por ejemplo, usando `openssl rand -hex 32`).
JWT_SECRET="your_jwt_secret_key_minimum_32_characters_long"

# Puerto en el que escuchará el servidor backend (NestJS).
PORT=4000

# URL del Frontend permitida para solicitudes de origen cruzado (CORS).
# En desarrollo suele ser http://localhost:3000, y en producción la URL de Vercel.
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"

# OAuth social login
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"
APPLE_CLIENT_ID="your_apple_service_id"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# -------------------------------------------------------------------------
# 2. CONFIGURACIÓN DEL FRONTEND (Next.js)
# -------------------------------------------------------------------------

# URL pública centralizada de la API del Backend.
# Al llevar el prefijo 'NEXT_PUBLIC_', esta variable estará expuesta en el lado del cliente de Next.js.
# En desarrollo suele ser http://localhost:4000/api, y en producción la URL de Render.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
